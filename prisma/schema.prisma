// tpass-appeals 資料模型。跟 tpass-form 的 JSONB「表單引擎」不同：
// 這裡只有一份申訴表單，題目彼此獨立、無分段/跳轉，所以用一張欄位化的
// Question 表就夠了，不需要大 JSON 文件 + 樂觀鎖那套機制。
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 學生會 email 白名單（超管種子來自 env，不入此表）。
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String // 操作者 email
  createdAt DateTime @default(now())
}

// 單例設定列（id 固定 "singleton"）：申訴系統只有一份表單，用 key-value 表反而過度設計。
model AppealSettings {
  id                 String  @id @default("singleton")
  title              String  @default("學生申訴系統")
  introText          String  @default("")
  discordWebhookUrl  String?
  acceptingResponses Boolean @default(true)
}

model Question {
  id          String   @id @default(cuid())
  order       Int
  type        String // short_text | paragraph | single_choice | multi_choice | file_upload
  title       String
  description String?
  required    Boolean  @default(false)
  options     Json? // [{id,label}]，單選/多選才有
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Appeal {
  id              String   @id @default(cuid())
  respondentSub   String
  respondentName  String
  respondentEmail String
  respondentGrade Int?
  answers         Json // { [questionId]: value }，送出當下的快照
  submittedAt     DateTime @default(now())

  @@index([submittedAt])
}

// 檔案上傳題：送出前先傳，answers 內存 id 參照。存放機制見 src/lib/storage.ts。
model Upload {
  id          String   @id @default(cuid())
  questionId  String
  storageKey  String
  filename    String
  mime        String
  size        Int
  uploaderSub String
  createdAt   DateTime @default(now())

  @@index([questionId])
}
